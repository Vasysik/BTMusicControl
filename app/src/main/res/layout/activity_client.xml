<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">
        
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:id="@+id/card_art"
            android:layout_width="320dp"
            android:layout_height="320dp"
            card_view:cardCornerRadius="16dp"
            card_view:cardElevation="8dp"
            card_view:contentPadding="4dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/iv_album_art"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_media_play"
                android:background="?android:attr/colorPrimaryDark"
                android:padding="64dp"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_track"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="8dp"/>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="?android:attr/colorAccent"
                android:thumbTint="?android:attr/colorAccent"/>

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="00:00 / 00:00"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:gravity="center"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Нет соединения"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp"/>
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <ImageButton
                android:id="@+id/btn_vol_down"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_vol_down"
                android:background="?selectableItemBackgroundBorderless"
                android:tint="?android:attr/textColorSecondary"/>

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_prev"
                android:background="?selectableItemBackgroundBorderless"
                android:tint="?android:attr/textColorPrimary"
                android:layout_marginHorizontal="4dp"/>

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_play_pause"
                android:background="?selectableItemBackgroundBorderless"
                android:tint="?android:attr/colorAccent"
                android:layout_marginHorizontal="4dp"/>

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_next"
                android:background="?selectableItemBackgroundBorderless"
                android:tint="?android:attr/textColorPrimary"
                android:layout_marginHorizontal="4dp"/>

            <ImageButton
                android:id="@+id/btn_vol_up"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_vol_up"
                android:background="?selectableItemBackgroundBorderless"
                android:tint="?android:attr/textColorSecondary"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_saved_device"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Устройство не привязано"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btn_connect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Выбрать устройство"/>
            
            <Button
                android:id="@+id/btn_forget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Отключиться"
                android:textColor="@android:color/white"
                android:backgroundTint="#D32F2F"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
