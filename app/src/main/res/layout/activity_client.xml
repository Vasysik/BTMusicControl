<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎮 Режим ПУЛЬТА"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="❌ Нет соединения"
        android:textSize="18sp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tv_track"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textStyle="italic"
        android:textColor="?android:attr/textColorSecondary"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Привязанное устройство -->
    <TextView
        android:id="@+id/tv_saved_device"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Устройство не привязано"
        android:textSize="13sp"
        android:textColor="?android:attr/textColorSecondary"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btn_connect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Выбрать устройство"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_forget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕ Забыть"
            android:visibility="gone"
            android:backgroundTint="#CC3333"/>

    </LinearLayout>

    <!-- Управление воспроизведением -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btn_prev"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="⏮"
            android:textSize="28sp"/>

        <Button
            android:id="@+id/btn_play"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="⏯"
            android:textSize="28sp"
            android:layout_marginHorizontal="16dp"/>

        <Button
            android:id="@+id/btn_next"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="⏭"
            android:textSize="28sp"/>

    </LinearLayout>

    <!-- Громкость -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_vol_down"
            android:layout_width="80dp"
            android:layout_height="64dp"
            android:text="🔉"
            android:textSize="26sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Громкость"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginHorizontal="16dp"/>

        <Button
            android:id="@+id/btn_vol_up"
            android:layout_width="80dp"
            android:layout_height="64dp"
            android:text="🔊"
            android:textSize="26sp"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Управление также через KeyMapper"
        android:textSize="11sp"
        android:textColor="?android:attr/textColorHint"
        android:layout_marginTop="24dp"/>

</LinearLayout>
