<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp">
        
        <androidx.cardview.widget.CardView
            android:id="@+id/card_art"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardCornerRadius="20dp"
            card_view:cardElevation="10dp"
            card_view:cardPreventCornerOverlap="false"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/iv_album_art"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_media_play"
                android:background="?android:attr/colorPrimaryDark"
                android:padding="80dp"/>

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_track"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="?android:attr/colorAccent"
                android:thumbTint="?android:attr/colorAccent"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_time_current"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="00:00"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:gravity="start"
                    android:paddingStart="4dp"/>

                <TextView
                    android:id="@+id/tv_time_total"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="00:00"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:gravity="end"
                    android:paddingEnd="4dp"/>

            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <ImageButton
                android:id="@+id/btn_vol_down"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_vol_down"
                android:scaleType="fitCenter"
                android:background="?selectableItemBackgroundBorderless"
                android:tint="?android:attr/textColorSecondary"
                android:padding="4dp"/>

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_prev"
                android:scaleType="fitCenter"
                android:background="?selectableItemBackgroundBorderless"
                android:tint="?android:attr/textColorPrimary"
                android:padding="4dp"
                android:layout_marginHorizontal="4dp"/>

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_play_pause"
                android:scaleType="fitCenter"
                android:background="@drawable/bg_circle_purple"
                android:tint="@android:color/white"
                android:padding="14dp"
                android:layout_marginHorizontal="4dp"/>

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_next"
                android:scaleType="fitCenter"
                android:background="?selectableItemBackgroundBorderless"
                android:tint="?android:attr/textColorPrimary"
                android:padding="4dp"
                android:layout_marginHorizontal="4dp"/>

            <ImageButton
                android:id="@+id/btn_vol_up"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_vol_up"
                android:scaleType="fitCenter"
                android:background="?selectableItemBackgroundBorderless"
                android:tint="?android:attr/textColorSecondary"
                android:padding="4dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_saved_device"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Устройство не привязано"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_connect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выбрать устройство"/>

            <ImageButton
                android:id="@+id/btn_forget"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_close"
                android:scaleType="fitCenter"
                android:background="@drawable/bg_circle_red"
                android:tint="@android:color/white"
                android:padding="12dp"
                android:layout_marginStart="12dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
